# Optional extraction settings only.
# These variables are not required for normal local app development or Vercel runtime.
# Use them when running `npm run extract` or `npm run convert:schema`.

# Required for extraction/schema conversion.
LLM_API_KEY=

# Optional overrides used by scripts/extract-epds/options.ts.
LLM_MODEL=deepseek-v4-flash
LLM_API_URL=https://api.deepseek.com
OCR_DPI=200
